  "keyFeatures": [
    "User management (ban, mute, kick, warn) with customizable actions",
    "Anti-spam with configurable flood control and blacklist filtering",
    "Welcome/goodbye messages with variable substitution",
    "Keyword-triggered filters with regex support and Aho-Corasick matching",
    "Notes system for saving and retrieving formatted messages",
    "Message locks (links, forwards, media types)",
    "CAPTCHA verification for new members",
    "Multi-language support (en, es, fr, hi, ru, pt, id)",
    "Both polling and webhook deployment modes",
    "Redis caching with stampede protection and PostgreSQL persistence",
    "OpenTelemetry distributed tracing",
    "One-click deploy to Render, Railway, and Heroku"
  ],
  "publicApiSurface": [
    "/start — Start the bot",
    "/help — Get module help",
    "/ban, /unban — Ban/unban users",
    "/mute, /unmute — Mute/unmute users",
    "/kick — Kick a user",
    "/warn, /unwarn — Warn/remove warnings",
    "/promote, /demote — Manage admin privileges",
    "/filter, /filters, /stop — Keyword filters",
    "/save, /get, /notes, /clear — Notes system",
    "/setwelcome, /setgoodbye — Greetings configuration",
    "/blacklist — Word/sticker blacklisting",
    "/lock, /unlock — Message type locks",
    "/setflood — Anti-flood configuration",
    "/rules — Group rules management",
    "/captcha — CAPTCHA verification settings",
    "/backup — Group data backup/restore",
    "/connect — Connect to groups from PM"
  ]
}
